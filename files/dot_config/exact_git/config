[init]
  defaultBranch = main
[user]
  useConfigOnly = true
[core]
  quotepath = false
  autoCRLF = false
  ignorecase = false
  pager = delta
[pager]
  branch = emojify
  log = emojiless
[interactive]
  diffFilter = delta
[merge]
  conflictstyle = diff3
[alias]
  # https://hackerslab.aktsk.jp/git-base-branch
  current-branch = symbolic-ref --short HEAD
  base-branch = !git config "branch.$(git current-branch).base"
  base-branch-remote = !echo "$(git config branch.$(git base-branch).remote)/$(git base-branch)"
  log-topic-branch = !git log $(git base-commit-long)..HEAD
  base-commit-long = !git merge-base origin/$(git base-branch) HEAD
  base-commit = !git rev-parse --short $(git base-commit-long)
  graph = log --graph --pretty=format:'%C(blue)%h%C(reset) - %C(white)%s%C(reset) %C(dim white)- %an%C(reset) %C(yellow)%d%C(reset)' --abbrev-commit --date=relative --color=always
  profile = user --config ~/.config/git/profiles
  commit-language = !git config commit.language
[color]
  ui = auto
[push]
  default = nothing
[pull]
  autoStash = true
  ff = only
[rebase]
  autoStash = true
  autoSquash = true
[status]
  showUntrackedFiles = all
[commit]
  verbose = true
  cleanup = scissors
  language = "英語"
[fetch]
  prune = true
[diff]
  indentHeuristic = true
  colorMoved = default
[advice]
  statusHints = false
  skippedCherryPicks = false
[ghq]
  user = "844196"
  root = ~/.ghq
[credential]
  helper = "!f() { ~/.844196/libexec/git-credential-manager-proxy $*; }; f"
[delta]
  navigate = true
  true-color = always
  features = tokyonight_night line-numbers
[delta "tokyonight_night"]
  syntax-theme = tokyonight_night
  file-style = bold "#7aa2f7"
  file-decoration-style = "#3b4261" ul
  hunk-header-style = omit
  minus-style = syntax "#37222c"
  minus-non-emph-style = syntax "#37222c"
  minus-emph-style = syntax "#713137"
  minus-empty-line-marker-style = syntax "#37222c"
  plus-style = syntax "#20303b"
  plus-non-emph-style = syntax "#20303b"
  plus-emph-style = syntax "#2c5a66"
  plus-empty-line-marker-style = syntax "#20303b"
[delta "line-numbers"]
  line-numbers = true
  line-numbers-left-style = "#3b4261"
  line-numbers-right-style = line-numbers-left-style
  line-numbers-zero-style = "#3b4261"
  line-numbers-plus-style = "#449dab"
  line-numbers-minus-style = "#914c54"
[delta "side-by-side"]
  side-by-side = true
