#!/usr/bin/env bash
# セッションIDから JSONL ファイルのパスを解決する。
#
# Usage: resolve-session-path <session-id>
#
# CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR=1 で cwd が安定し、かつ
# プロジェクトルートでしか claude code を起動しない運用なので、
# プロジェクトの slug は cwd から導出できる。
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: resolve-session-path <session-id>" >&2
    exit 1
fi

sid="$1"
slug=$(pwd | tr '/.' '-')
path="$HOME/.claude/projects/$slug/$sid.jsonl"

if [[ ! -f "$path" ]]; then
    echo "Session $sid not found at $path" >&2
    exit 1
fi

echo "$path"
