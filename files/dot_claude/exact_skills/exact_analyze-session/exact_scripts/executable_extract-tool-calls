#!/usr/bin/env python3
"""セッションログからツールコールを抽出し、時系列で表示する。

Usage: extract-tool-calls <jsonl-path> [--errors-only] [--with-output]
"""
import sys
import json
import argparse

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("jsonl", help="Path to session .jsonl file")
    parser.add_argument("--errors-only", action="store_true", help="Show only failed tool calls")
    parser.add_argument("--with-output", action="store_true", help="Include tool output (truncated)")
    parser.add_argument("--output-limit", type=int, default=500, help="Max chars for tool output (default: 500)")
    args = parser.parse_args()

    # Pass 1: collect tool_use calls from assistant messages
    tool_calls = {}  # id -> {name, input, index}
    # Pass 2: match tool_result from user messages
    results = {}  # tool_use_id -> {content, is_error}

    entries = []
    with open(args.jsonl) as f:
        for line in f:
            entries.append(json.loads(line))

    call_order = []
    for obj in entries:
        msg = obj.get("message", {})

        # assistant tool_use
        if msg.get("role") == "assistant":
            for block in msg.get("content", []):
                if block.get("type") == "tool_use":
                    tid = block["id"]
                    tool_calls[tid] = {
                        "name": block["name"],
                        "input": block.get("input", {}),
                    }
                    call_order.append(tid)

        # user message containing tool_result
        if obj.get("type") == "user":
            content = msg.get("content", "")
            if isinstance(content, list):
                for c in content:
                    if isinstance(c, dict) and c.get("type") == "tool_result":
                        results[c["tool_use_id"]] = {
                            "content": c.get("content", ""),
                            "is_error": c.get("is_error", False),
                        }

    for tid in call_order:
        call = tool_calls[tid]
        result = results.get(tid, {})
        is_error = result.get("is_error", False)

        if args.errors_only and not is_error:
            continue

        status = "FAIL" if is_error else "OK"
        name = call["name"]
        inp = call["input"]

        # Format input summary
        if name == "Bash":
            summary = inp.get("command", "")[:120]
        elif name == "Read":
            summary = inp.get("file_path", "")
        elif name == "Write":
            summary = inp.get("file_path", "")
        elif name == "Edit":
            summary = f'{inp.get("file_path", "")} (edit)'
        elif name == "Glob":
            summary = inp.get("pattern", "")
        elif name == "Grep":
            summary = f'/{inp.get("pattern", "")}/ in {inp.get("path", ".")}'
        elif name == "Agent":
            summary = inp.get("description", inp.get("prompt", "")[:80])
        elif name == "Skill":
            summary = inp.get("skill", "")
        else:
            summary = json.dumps(inp, ensure_ascii=False)[:120]

        print(f"[{status}] {name}: {summary}")

        if args.with_output and result.get("content"):
            content = result["content"]
            limit = args.output_limit
            if len(content) > limit:
                content = content[:limit] + f"... ({len(content)} chars total)"
            for line in content.split("\n"):
                print(f"       {line}")


if __name__ == "__main__":
    main()
