#!/usr/bin/env python3
"""セッションIDからJSONLファイルのパスを解決する。

Usage: resolve-session-path <session-id> [--project-dir <dir>]

--project-dir を省略した場合、~/.claude/projects/ 以下の全プロジェクトから検索する。
"""
import sys
import os
import argparse
from pathlib import Path

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("session_id", help="Session UUID")
    parser.add_argument("--project-dir", help="Limit search to specific project slug dir")
    args = parser.parse_args()

    base = Path.home() / ".claude" / "projects"
    sid = args.session_id

    if args.project_dir:
        candidates = [base / args.project_dir / f"{sid}.jsonl"]
    else:
        candidates = list(base.glob(f"*/{sid}.jsonl"))

    found = [p for p in candidates if p.exists()]
    if not found:
        print(f"Session {sid} not found", file=sys.stderr)
        sys.exit(1)

    for p in found:
        print(str(p))


if __name__ == "__main__":
    main()
