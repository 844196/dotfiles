{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "タメでいいよ",
  "includeGitInstructions": false,
  "env": {
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_SHELL": "zsh",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "3",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "ENABLE_LSP_TOOL": "true",
    "GIT_PAGER": "cat",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh",
  "attribution": {
    "commit": "Co-Authored-By: Claude <model> <noreply@anthropic.com>"
  },
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["I'm gonna act super cute"]
  },
  "agentPushNotifEnabled": false,
  "remoteControlAtStartup": false,
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.envrc)",
      "Read(**/mise.local.toml)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)",
      "Bash(git branch -m *)",
      "Bash(git branch -M *)",
      "Bash(git branch --force *)",
      "Bash(git rm *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(gh pr create *)"
    ],
    "allow": [
      "WebSearch",
      "Write",
      "Edit",
      "Bash(claude --version)",
      "Bash(mise --version)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(git branch *)",
      "Bash(git current-branch)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git grep *)",
      "Bash(git diff *)",
      "Bash(git create-topic-branch *)",
      "Bash(git log-topic-branch)",
      "Bash(git diff-topic-branch)",
      "Bash(git base-branch)",
      "Bash(git base-branch-remote)",
      "Bash(git base-commit-long)",
      "Bash(git base-commit)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git commit-language)",
      "Bash(git claude-attribution)",
      "Bash(git fetch *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh search *)",
      "Bash(chroma *)",
      "Bash(claude-yolo --split-pane *)",
      "Bash(command -v difit)",
      "Bash(difit *)",
      "Bash(handover-path.sh)",
      "Bash(transcript-path *)",
      "Bash(read-checklist.sh)",
      "Bash(claude-p2p poll)",
      "Bash(claude-p2p send *)",
      "Bash(claude-p2p read *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "mise x bun@1.3.12 -- bunx --bun ccstatusline@2.2.8"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "fastfetch --logo none --structure-disabled colors"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "844196-dotfiles": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.claude/local-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "agent-teams@844196-dotfiles": false,
    "atuin@844196-dotfiles": true,
    "block-long-sleep@844196-dotfiles": true,
    "claude-code-meta@844196-dotfiles": true,
    "done-check@844196-dotfiles": true,
    "edit-reminders@844196-dotfiles": false,
    "git@844196-dotfiles": true,
    "github@844196-dotfiles": true,
    "mise@844196-dotfiles": true,
    "new-file-protocol@844196-dotfiles": true,
    "notification@844196-dotfiles": true,
    "p2p@844196-dotfiles": true,
    "personal-scratchpad@844196-dotfiles": true,
    "session-analyzer@844196-dotfiles": true,
    "tmux-helpers@844196-dotfiles": true
  },
  "skillOverrides": {
    "grill-me": "user-invocable-only",
    "skill-creator": "user-invocable-only",
    "claude-md-improver": "user-invocable-only",
    "revise-claude-md": "user-invocable-only"
  }
}
