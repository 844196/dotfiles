{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "タメでいいよ",
  "includeGitInstructions": false,
  "plansDirectory": ".844196/plans/",
  "env": {
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_SHELL": "zsh",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SCROLL_SPEED": "3",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "ENABLE_LSP_TOOL": "true",
    "GIT_PAGER": "cat",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "attribution": {
    "commit": "Co-Authored-By: Claude <model> <noreply@anthropic.com>"
  },
  "tui": "fullscreen",
  "theme": "custom:tokyonight:tokyonight-moon",
  "syntaxHighlightingDisabled": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["I'm gonna act super cute"]
  },
  "agentPushNotifEnabled": false,
  "remoteControlAtStartup": false,
  "respondToBashCommands": false,
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.envrc)",
      "Read(**/mise.local.toml)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)",
      "Bash(git branch -m *)",
      "Bash(git branch -M *)",
      "Bash(git branch --force *)",
      "Bash(git rm *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(gh pr create *)"
    ],
    "allow": [
      "WebSearch",
      "Bash(claude --version)",
      "Bash(mise --version)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(git branch *)",
      "Bash(git current-branch)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git grep *)",
      "Bash(git diff *)",
      "Bash(git create-topic-branch *)",
      "Bash(git log-topic-branch)",
      "Bash(git diff-topic-branch)",
      "Bash(git base-branch)",
      "Bash(git base-branch-remote)",
      "Bash(git base-commit-long)",
      "Bash(git base-commit)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git commit-language)",
      "Bash(git claude-attribution)",
      "Bash(git fetch *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh search *)",
      "Bash(chroma *)",
      "Bash(command -v difit)",
      "Bash(difit *)",
      "Bash(transcript-path *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline"
  },
  "fileSuggestion": {
    "type": "command",
    "command": "~/.dotfiles/packages/herdr-file-picker/claude-file-suggestion.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "fastfetch --logo none --structure-disabled colors"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "844196-dotfiles": {
      "source": {
        "source": "directory",
        "path": "{{ .dotfilesDir }}/packages/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "atuin@844196-dotfiles": true,
    "block-long-sleep@844196-dotfiles": true,
    "git@844196-dotfiles": true,
    "github@844196-dotfiles": true,
    "handover@844196-dotfiles": true,
    "herdr@844196-dotfiles": true,
    "one-pager@844196-dotfiles": true,
    "mise@844196-dotfiles": true,
    "new-file-protocol@844196-dotfiles": true,
    "notification@844196-dotfiles": true,
    "personal-scratchpad@844196-dotfiles": true,
    "tokyonight@844196-dotfiles": true,
    "what-would-you-do@844196-dotfiles": true
  },
  "pluginConfigs": {
    "git@844196-dotfiles": {
      "options": {
        "COMMIT_MESSAGE_LANGUAGE": "英語"
      }
    },
    "handover@844196-dotfiles": {
      "options": {
        "HANDOVER_OUTPUT_PATH_FORMAT": "`$(git rev-parse --show-toplevel)/.844196/handovers/$(date +%Y%m%d%H%M%S)_<kebab-case>.md` (`<kebab-case>` は内容を表す名前に置換すること)",
        "CLAUDE_COMMAND": "claude-yolo"
      }
    },
    "herdr@844196-dotfiles": {
      "options": {
        "CLAUDE_COMMAND": "claude-yolo"
      }
    }
  },
  "skillOverrides": {
    "grill-me": "user-invocable-only",
    "skill-creator": "user-invocable-only",
    "claude-md-improver": "user-invocable-only",
    "revise-claude-md": "user-invocable-only"
  }
}
