{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/ja/keybindings",
  "bindings": [
    {
      "context": "Global",
      "bindings": {
        "ctrl+l": "app:redraw"
      }
    },
    {
      "context": "Chat",
      "bindings": {
        "ctrl+q": "chat:stash",
        "ctrl+l": null,
        "ctrl+g": null,
        "escape": null
      }
    }
  ]
}
