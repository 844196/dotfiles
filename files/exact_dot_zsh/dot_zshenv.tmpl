# vim: set ft=zsh:

export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state
{{- if eq .chezmoi.os "darwin" }}
# https://stackoverflow.com/questions/14237142/xdg-runtime-dir-on-mac-os-x
export XDG_RUNTIME_DIR="${$(getconf DARWIN_USER_TEMP_DIR)%/}"
{{- end }}

ZDOTDIR=$HOME/.zsh

# ignore /etc/zprofile, /etc/zshrc, /etc/zlogin, and /etc/zlogout
# ref. http://zsh.sourceforge.net/Doc/Release/Files.html
# ref. http://zsh.sourceforge.net/Doc/Release/Options.html#index-GLOBALRCS
unsetopt GLOBAL_RCS

{{- if eq .chezmoi.os "darwin" }}
# system-wide environment settings for zsh(1)
if [[ -x /usr/libexec/path_helper ]]; then
  eval `/usr/libexec/path_helper -s`
fi
{{- end }}

# Disable execution compinit in ubuntu distributed global zshrc (/etc/zsh/zshrc)
# SEE: https://www.zsh.org/mla/users/2021/msg00879.html
skip_global_compinit=1

typeset -U {,F,MAN}PATH {,f,man}path
path=(
  ~/.opt/dotfiles/bin(N-/)
  ~/.opt/dotfiles/mise-tool-stubs(N-/)
  ~/.opt/dotfiles/opt/git-add-A/bin(N-/)

  $XDG_DATA_HOME/mise/shims(N-/)

  # Conventional user-level bin directories
  ~/.local/bin(N-/)
  ~/bin(N-/)

  # Rancher
  ~/.rd/bin(N-/)

  # GNU CLI tools via Homebrew
  /opt/homebrew/opt/coreutils/libexec/gnubin(N-/)
  /opt/homebrew/opt/grep/libexec/gnubin(N-/)
  /opt/homebrew/opt/gnu-sed/libexec/gnubin(N-/)
  /opt/homebrew/opt/gnu-tar/libexec/gnubin(N-/)
  /opt/homebrew/opt/gawk/libexec/gnubin(N-/)

  # Homebrew
  /opt/homebrew/bin(N-/)

  $path
)
fpath=(
  $ZDOTDIR/functions/*(N-/)
  $ZDOTDIR/functions/Completion/*(N-/)
  $XDG_DATA_HOME/anyframe(N-/)
  $XDG_DATA_HOME/zman/functions(N-/)
  $XDG_DATA_HOME/zsh/site-functions(N-/)
  $fpath
)

export CURL_HOME=$XDG_CONFIG_HOME/curl

export WGETRC=$XDG_CONFIG_HOME/wget/wgetrc

export LESSKEY=$XDG_CONFIG_HOME/less/.less

export AWS_ECR_CACHE_DIR=$XDG_CACHE_HOME/ecr

export FZF_DEFAULT_OPTS_FILE=$XDG_CONFIG_HOME/fzf/config

export DENO_NO_UPDATE_CHECK=1

if [[ -f $ZDOTDIR/.zshenv.local ]]; then
  source $ZDOTDIR/.zshenv.local
fi
