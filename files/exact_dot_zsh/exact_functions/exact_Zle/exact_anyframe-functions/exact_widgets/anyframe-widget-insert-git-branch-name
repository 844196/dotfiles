# vim: set ft=zsh:

tput cub 9999

~/.opt/dotfiles/opt/git-branch-pretty/libexec/git-branch-pretty "$@" \
  | SHELL==$ZSH_NAME anyframe-selector-fzf '' \
    --preview '~/.opt/dotfiles/opt/fzf-preview-helper/libexec/fzf-preview-helper git-branch {1}' \
  | cut -d ' ' -f 1,1 \
  | anyframe-action-insert

zle redisplay
