# vim: set ft=zsh:

tput cub 9999

~/.opt/dotfiles/opt/git-status-pretty/libexec/git-status-pretty \
  | SHELL==$ZSH_NAME anyframe-selector-fzf '' \
    --multi \
    --select-1 \
    --delimiter '│' \
    --nth 2.. \
    --scheme path \
    --preview-window +2 \
    --preview '~/.opt/dotfiles/opt/fzf-preview-helper/libexec/fzf-preview-helper git-status {}' \
  | sed 's/^.....//g' \
  | anyframe-action-insert

zle redisplay
