# vim: set ft=zsh:
# cSpell:words psvar

if (( ${INCOGNITO-0} )); then
  fc -P

  zstyle ':prompt:zen:notice' show no
  psvar[$__ZEN_PSVAR_INDEXES[notice]]=

  INCOGNITO=
else
  fc -p

  zstyle ':prompt:zen:notice' show yes
  zstyle ':prompt:zen:notice' override $'\Uf05f9 '
  psvar[$__ZEN_PSVAR_INDEXES[notice]]=$'\Uf05f9 '

  INCOGNITO=1
fi

zle reset-prompt
