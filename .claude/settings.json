{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": ".agents/plans",
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "844196/dotfiles"
  },
  "permissions": {
    "deny": [
      "Bash(chezmoi apply)"
    ],
    "ask": [
      "Bash(mise run //:chezmoi:apply)"
    ],
    "allow": [
      "Bash(mise run //:chezmoi:diff)"
    ]
  }
}
